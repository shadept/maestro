# Maestro orchestrator configuration.
#
# Copy to `.env` at the repo root (or next to apps/orchestrator) and fill in
# the required values; `.env` is gitignored. Loaded at boot as a dev
# convenience — real environment variables always take precedence over `.env`
# values, and a missing `.env` is fine. Every variable listed here is read and
# validated in apps/orchestrator/src/config/AppConfig.ts; nothing else reads
# the environment.

# ── Core ────────────────────────────────────────────────────────────────────

# Postgres connection string for orchestrator state and the pg-boss queue. Required.
# This value matches the docker-compose.yml Postgres defaults.
DATABASE_URL=postgresql://maestro:maestro@localhost:5432/maestro

# Bearer token protecting the admin API and admin UI. Required.
MAESTRO_ADMIN_TOKEN=change-me

# HTTP port the orchestrator listens on. Optional, default: 3000.
#MAESTRO_PORT=3000

# Log output format: "json" or "pretty". Optional, default: json.
#MAESTRO_LOG_FORMAT=json

# Directory the admin UI static bundle is served from. Optional,
# default: the admin-ui workspace's Vite output (apps/admin-ui/dist).
#MAESTRO_ADMIN_UI_DIST=/path/to/admin-ui/dist

# ── Storage & worker runtime ────────────────────────────────────────────────

# Root directory for git caches, session worktrees, and session config dirs. Required.
MAESTRO_STORAGE_ROOT=/var/lib/maestro

# Which worker runtime to use: "local-cli" (container CLI) or "k8s" (Jobs).
# Optional, default: local-cli.
#MAESTRO_RUNTIME_MODE=local-cli

# Container runtime CLI template for local-cli mode (docker/podman/nerdctl).
# Optional, default: "docker run".
#MAESTRO_RUNTIME_TEMPLATE=docker run

# Container image every agent turn runs in. Optional, default: maestro/worker-base:latest.
#MAESTRO_WORKER_IMAGE=maestro/worker-base:latest

# Maximum number of worker containers running at once. Optional, default: 2.
#MAESTRO_MAX_CONCURRENT_WORKERS=2

# Hard per-turn execution deadline in seconds. Optional, default: 1800 (30 min).
#MAESTRO_TURN_TIMEOUT_SECONDS=1800

# Idle minutes before a session cools down and its worktree is reclaimed. Optional, default: 60.
#MAESTRO_COOLDOWN_MINUTES=60

# Days completed sessions and artifacts are retained before cleanup. Optional, default: 14.
#MAESTRO_RETENTION_DAYS=14

# ── Git & forge (GitHub) ────────────────────────────────────────────────────

# GitHub token (PAT or app token) the orchestrator uses to push session
# branches and open PRs. Optional at boot — without it, publishing fails
# per-invocation, nothing else does.
#MAESTRO_GITHUB_TOKEN=ghp_your-token-here

# Commit author identity for Maestro-made commits.
# Optional, defaults: "Maestro" / "maestro@localhost".
#MAESTRO_GIT_AUTHOR_NAME=Maestro
#MAESTRO_GIT_AUTHOR_EMAIL=maestro@localhost

# ── Linear ingestion & callbacks ────────────────────────────────────────────

# Linear webhook signing secret. Optional at boot — without it the webhook
# endpoint rejects every delivery (signature verification cannot run).
#MAESTRO_LINEAR_WEBHOOK_SECRET=lin_wh_your-secret-here

# Linear API token for outbound callbacks (posting turn results as comments).
# Accepts either a personal API key (lin_api_ prefix; comments appear authored
# by that human) or an OAuth app-actor access token (comments appear authored
# by the Maestro app — recommended, see DOGFOOD.md "Posting as the Maestro
# app"). Optional at boot — absent token fails per-post.
#MAESTRO_LINEAR_API_TOKEN=lin_api_your-token-here

# How MAESTRO_LINEAR_API_TOKEN authenticates: "api-key" (personal key, raw
# Authorization header) or "oauth" (app token, Bearer header). Optional —
# absent means auto-detect by the lin_api_ prefix, which is right for every
# token Linear currently issues. Set "api-key" only for a legacy personal key
# without the prefix.
#MAESTRO_LINEAR_TOKEN_KIND=oauth

# Label that hands a Linear issue to Maestro. Optional, default: maestro.
#MAESTRO_LINEAR_TRIGGER_LABEL=maestro

# Linear user id of the account MAESTRO_LINEAR_API_TOKEN belongs to — the
# self-trigger guard: comments by this user never queue turns. With an OAuth
# app token this is the app's own user id (query `{ viewer { id } }` with the
# app token — see DOGFOOD.md), which makes the guard reliable again. Optional.
#MAESTRO_LINEAR_BOT_USER_ID=00000000-0000-0000-0000-000000000000

# ── Agent authentication (claude-code in workers) ───────────────────────────

# Claude subscription session token (preferred). Optional; one of the two
# agent credentials is needed for turns to run.
#CLAUDE_CODE_OAUTH_TOKEN=your-oauth-token-here

# Anthropic API key — fallback when no OAuth token is set. Optional.
#ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── Agent model & effort (FUR-41) ───────────────────────────────────────────

# Deployment-default model for worker turns, passed as `claude --model`.
# Optional — absent means the claude CLI's own default. Overridable per
# project (register-project --agent-model) and per task (Linear label
# `maestro:model=<id>`); most specific wins. Invalid ids fail the turn with
# the CLI's error visible in the run logs.
#MAESTRO_AGENT_MODEL=claude-sonnet-4-5

# Deployment-default effort level, passed as `claude --effort`.
# One of: low, medium, high, xhigh, max. Optional — absent means the CLI
# default. Overridable per project (--agent-effort) and per task
# (`maestro:effort=<level>` label).
#MAESTRO_AGENT_EFFORT=medium
